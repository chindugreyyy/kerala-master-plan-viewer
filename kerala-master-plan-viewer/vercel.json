{
  "version": 2,
  "name": "kerala-master-plan-viewer",
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin/(.*)", "dest": "/admin.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.(json|css|js|png|jpg|ico|txt|xml|csv|md|py))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "github": {
    "enabled": true,
    "autoAlias": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}

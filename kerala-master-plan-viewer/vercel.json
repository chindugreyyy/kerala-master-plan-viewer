{
  "version": 2,
  "name": "kerala-master-plan-viewer",
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin/(.*)", "dest": "/admin.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.(json|css|js|png|jpg|ico|txt|xml|csv|md|py|tif|tiff))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "github": {
    "enabled": true,
    "autoAlias": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, HEAD, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Range, Content-Type"
        },
        {
          "key": "Access-Control-Expose-Headers",
          "value": "Content-Range, Content-Length"
        }
      ]
    }
  ]
}
